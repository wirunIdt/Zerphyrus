SECRET_KEY=replace-with-a-long-random-secret
FLASK_DEBUG=0
PORT=8000
PREFERRED_SCHEME=https
COMPANY_NAME=Zerphyrus
PROMPTPAY_PHONE=0812345678
PROMPTPAY_QR_IMAGE=

# Data backend: json for local/dev, supabase for Vercel production
DATA_BACKEND=json
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=replace-with-your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-your-supabase-service-role-key
SUPABASE_STORAGE_BUCKET=zerphyrus-uploads
SUPABASE_STORAGE_PUBLIC=0
SUPABASE_TIMEOUT=20

# Optional LINE integration
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
ADMIN_LINE_USER_ID=

# Optional email integration
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TLS=1

# Optional SMS integration
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# Optional business settings
MONTHLY_REVENUE_TARGET=0
VAT_RATE=7
